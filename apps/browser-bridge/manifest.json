{
  "manifest_version": 3,
  "name": "Papyrus Browser Bridge",
  "version": "1.0.0",
  "description": "Connect Papyrus to one user-authorized Chromium tab with a constrained accessibility protocol.",
  "permissions": ["tabs", "activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": { "service_worker": "service_worker.js", "type": "module" },
  "action": { "default_title": "Papyrus Browser Bridge", "default_popup": "popup.html" }
}
