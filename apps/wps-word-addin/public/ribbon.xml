<?xml version="1.0" encoding="UTF-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="OnAddinLoad">
  <ribbon startFromScratch="false">
    <tabs>
      <tab id="tabPapyrus" label="Papyrus">
        <group id="groupPapyrusWriting" label="WPS 文学秘书">
          <button
            id="btnPapyrusTaskPane"
            label="打开 Papyrus"
            size="large"
            onAction="ShowPapyrusTaskPane"
            getEnabled="GetEnabled"
            getVisible="GetVisible"
            screentip="打开 Papyrus 侧栏"
            supertip="在 WPS 右侧打开 Papyrus 文学秘书与写作工作台。"
          />
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
