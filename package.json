{
  "name": "papyrus",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "wps:dev": "vite --config apps/wps-word-addin/vite.config.ts",
    "wps:build": "tsc -p apps/wps-word-addin/tsconfig.json && vite build --config apps/wps-word-addin/vite.config.ts && powershell -ExecutionPolicy Bypass -File scripts/prepare-wps-addin-dist.ps1",
    "wps:install": "powershell -ExecutionPolicy Bypass -File scripts/sync-wps-addin.ps1",
    "wps:package": "npm run wps:build && powershell -ExecutionPolicy Bypass -File scripts/package-wps-addin-release.ps1",
    "wps:debug": "powershell -ExecutionPolicy Bypass -File scripts/read-wps-addin-debug.ps1",
    "wps:preview": "vite preview --config apps/wps-word-addin/vite.config.ts",
    "test:wps": "vitest run --config apps/wps-word-addin/vite.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:desktop": "npm run test:unit && node scripts/run-cargo-desktop.mjs test --locked",
    "check:desktop": "npm run lint && npm run test:desktop && npm run build && npm run tauri:check:portable",
    "test:release-scripts": "node --test scripts/lib/release-checks.test.mjs",
    "browser:package": "npm run browser:build && node scripts/package-browser-bridge.mjs",
    "browser:build": "node scripts/build-browser-bridge.mjs",
    "browser:test": "node --test scripts/browser-bridge.test.mjs",
    "test:browser": "npm run browser:test && npm run test:unit -- src/services/browserAssistantIntegration.test.ts && vitest run --config apps/browser-bridge/vitest.config.ts",
    "check:browser": "npm run test:browser && npm run browser:build && cargo test --manifest-path src-tauri/Cargo.toml --locked browser_bridge && cargo test --manifest-path src-tauri/Cargo.toml --locked web_extract",
    "test:browser:e2e": "playwright test --config=playwright.config.ts",
    "release:assistant-check:local": "node scripts/check-work-assistant-release.mjs --phase local",
    "release:assistant-check": "node scripts/check-work-assistant-release.mjs --phase release",
    "ci:desktop": "npm run lint && npm run test:wps && npm run test:unit && npm run test:browser && npm run browser:build && npm run build && npm run test:release-scripts && npm run release:assistant-check",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:check:portable": "powershell -ExecutionPolicy Bypass -File scripts/with-portable-msvc.ps1 check",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/check-papyrus-release.ps1",
    "env:activate": "powershell -ExecutionPolicy Bypass -NoExit -File scripts/activate-portable-tools.ps1",
    "git:version": ".codex-tools\\MinGit\\cmd\\git.exe --version"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-mention": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/suggestion": "^3.23.6",
    "docx": "^9.6.1",
    "framer-motion": "^12.40.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
  "main": "eslint.config.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
