{
  "name": "papyrus",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "wps:dev": "vite --config apps/wps-word-addin/vite.config.ts",
    "wps:build": "tsc -p apps/wps-word-addin/tsconfig.json && vite build --config apps/wps-word-addin/vite.config.ts && powershell -ExecutionPolicy Bypass -File scripts/prepare-wps-addin-dist.ps1",
    "wps:install": "powershell -ExecutionPolicy Bypass -File scripts/sync-wps-addin.ps1",
    "wps:package": "npm run wps:build && powershell -ExecutionPolicy Bypass -File scripts/package-wps-addin-release.ps1",
    "wps:debug": "powershell -ExecutionPolicy Bypass -File scripts/read-wps-addin-debug.ps1",
    "wps:preview": "vite preview --config apps/wps-word-addin/vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:check:portable": "powershell -ExecutionPolicy Bypass -File scripts/with-portable-msvc.ps1 check",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/check-papyrus-release.ps1",
    "env:activate": "powershell -ExecutionPolicy Bypass -NoExit -File scripts/activate-portable-tools.ps1",
    "git:version": ".codex-tools\\MinGit\\cmd\\git.exe --version"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-mention": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/suggestion": "^3.23.6",
    "docx": "^9.6.1",
    "framer-motion": "^12.40.0",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "description": "This template provides a minimal setup to get React working in Vite with HMR and some ESLint rules.",
